# Firebase client config required by login, Firestore, and client-side features.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Mirror the same Firebase values at runtime for server routes that expose public config.
FIREBASE_PUBLIC_API_KEY=
FIREBASE_PUBLIC_AUTH_DOMAIN=
FIREBASE_PUBLIC_PROJECT_ID=
FIREBASE_PUBLIC_STORAGE_BUCKET=
FIREBASE_PUBLIC_MESSAGING_SENDER_ID=
FIREBASE_PUBLIC_APP_ID=
FIREBASE_PUBLIC_MEASUREMENT_ID=

# Required if you deploy the separate socket signaling service for radio/video features.
NEXT_PUBLIC_SOCKET_URL=

# Required for Firebase Data Connect-backed admin data.
DATA_CONNECT_SERVICE_ID=
DATA_CONNECT_LOCATION=europe-west1
DATA_CONNECT_CONNECTOR=admin

# Required only if blueprint parsing / Gemini-powered features are enabled.
GEMINI_API_KEY=

# Optional feature toggles.
NEXT_PUBLIC_BEACON_MODE=
NEXT_PUBLIC_ENABLE_PHYSICAL_BEACONS=false

# Optional MediaMTX integration.
MEDIAMTX_PRIMARY_LABEL=
MEDIAMTX_PRIMARY_API_URL=
NEXT_PUBLIC_MEDIAMTX_PRIMARY_LABEL=
NEXT_PUBLIC_MEDIAMTX_PRIMARY_WEBRTC_BASE_URL=
NEXT_PUBLIC_MEDIAMTX_PRIMARY_HLS_BASE_URL=

MEDIAMTX_FALLBACK_LABEL=
MEDIAMTX_FALLBACK_API_URL=
NEXT_PUBLIC_MEDIAMTX_FALLBACK_LABEL=
NEXT_PUBLIC_MEDIAMTX_FALLBACK_WEBRTC_BASE_URL=
NEXT_PUBLIC_MEDIAMTX_FALLBACK_HLS_BASE_URL=
